<ui:FluentWindow
    x:Class="Aria2Fast.View.Dialogs.AiConfigEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Aria2Fast.View.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:wpfutils="clr-namespace:Aria2Fast.Utils"
    Title="AI 配置"
    Width="520"
    Height="640"
    Background="{DynamicResource App.PageBackgroundBrush}"
    TextElement.Foreground="{DynamicResource App.TextPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="AI 配置"
            Grid.Row="0"
            ShowMaximize="False"
            ShowMinimize="False" />

        <ScrollViewer Grid.Row="1" Padding="20,12,20,12">
            <StackPanel>
                <TextBlock Foreground="{DynamicResource App.TextPrimaryBrush}" Text="快速预设" />
                <ComboBox
                    x:Name="PresetComboBox"
                    Margin="0,5,0,0"
                    DisplayMemberPath="DisplayName"
                    SelectionChanged="PresetComboBox_SelectionChanged" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="11"
                    Foreground="{DynamicResource App.TextSecondaryBrush}"
                    Text="选择预设可一键填入协议、地址与模型，仍可手动修改。" />

                <TextBlock
                    Margin="0,14,0,0"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    Text="配置名称" />
                <ui:TextBox
                    Margin="0,5,0,0"
                    PlaceholderText="例如：OpenAI 官方、公司中转"
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Margin="0,14,0,0"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    Text="协议类型" />
                <ComboBox
                    x:Name="ProtocolComboBox"
                    Margin="0,5,0,0"
                    DisplayMemberPath="DisplayName"
                    SelectionChanged="ProtocolComboBox_SelectionChanged" />

                <TextBlock
                    Margin="0,14,0,0"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    Text="API 地址（Base URL）" />
                <ui:TextBox
                    Margin="0,5,0,0"
                    PlaceholderText="例如：https://api.openai.com"
                    Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                <ui:Card Margin="0,8,0,0" Padding="12,10,12,10">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource App.TextSecondaryBrush}"
                            Text="实际请求地址" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="Consolas"
                            Foreground="{DynamicResource App.AccentBrush}"
                            Text="{Binding RequestUrlPreview}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ui:Card>

                <TextBlock
                    Margin="0,14,0,0"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    Text="模型名" />
                <ui:TextBox
                    Margin="0,5,0,0"
                    PlaceholderText="例如：gpt-4o-mini"
                    Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Margin="0,14,0,0"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    Text="API Key" />
                <ui:PasswordBox
                    Margin="0,5,0,0"
                    wpfutils:PasswordBoxAssistant.BindPassword="True"
                    wpfutils:PasswordBoxAssistant.BoundPassword="{Binding ApiKey, Mode=TwoWay}" />
            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Padding="20,12,20,16"
            BorderBrush="{DynamicResource App.SeparatorBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ui:Button
                    MinWidth="80"
                    Click="Cancel_Click"
                    Content="取消" />
                <ui:Button
                    MinWidth="80"
                    Margin="10,0,0,0"
                    Appearance="Primary"
                    Click="Save_Click"
                    Content="保存" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
