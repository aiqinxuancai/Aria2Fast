<Page
    x:Class="Aria2Fast.View.Aria2FastSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:Aria2Fast.View.Contver"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Aria2Fast.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:service="clr-namespace:Aria2Fast.Service"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:utils="clr-namespace:Aria2Fast.Utils"
    xmlns:wpfutils="clr-namespace:Aria2Fast.Utils"
    Title="Aria2FastSetting"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    TextElement.Foreground="{DynamicResource App.TextPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">


    <Page.Resources>
        <converter:NegationConverter x:Key="NegationConverter" />
        <converter:IsSelectedAria2NodeConverter x:Key="IsSelectedAria2NodeConverter" />
        <converter:IsSelectedAiConfigConverter x:Key="IsSelectedAiConfigConverter" />
        <converter:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <converter:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <converter:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
    </Page.Resources>


    <Grid>
        <ScrollViewer>
            <StackPanel Margin="10,10,6,6">
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    FontSize="28"
                    Text="设置" />
                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                    <TextBlock
                        x:Name="HomePageTextBlock"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource App.AccentBrush}"
                        MouseLeftButtonDown="HomePageTextBlock_MouseLeftButtonDown"
                        Text="Aria2Fast" />
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource App.TextPrimaryBrush}" Text=" 当前版本" />
                    <TextBlock Margin="2,0,0,0" Foreground="{DynamicResource App.TextPrimaryBrush}" Text="{Binding Source={x:Static utils:ActionVersion.Version}}" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource App.TextPrimaryBrush}"
                        Text="最新版本" />
                    <TextBlock
                        x:Name="BadgeNewVersion"
                        Margin="2,0,0,0"
                        Foreground="{DynamicResource App.AccentBrush}"
                        MouseLeftButtonDown="BadgeNewVersion_MouseLeftButtonDown"
                        Text="{Binding Source={x:Static utils:ActionVersion.NowGithubVersion}}" />
                </StackPanel>

                <TextBlock
                    Margin="0,15,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    FontSize="18"
                    Text="外观" />

                <ui:Card Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource App.TextPrimaryBrush}" Text="主题" />
                        <WrapPanel Margin="0,5,0,0">
                            <RadioButton
                                Content="自动"
                                GroupName="AppTheme"
                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.AppTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Auto}" MinWidth="80" />
                            <RadioButton
                                Content="浅色"
                                Margin="12,0,0,0"
                                GroupName="AppTheme"
                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.AppTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}" MinWidth="80" />
                            <RadioButton
                                Margin="12,0,0,0"
                                Content="深色"
                                GroupName="AppTheme"
                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.AppTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}" MinWidth="80"/>
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <StackPanel Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock
                            Margin="0,10,0,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource App.TextPrimaryBrush}"
                            FontSize="18"
                            Text="基础设置" />

                        <ui:Card x:Name="AccountCardAction" Margin="0,10,0,0">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton
                                                Content="本机Aria2"
                                                GroupName="Aria2Mode"
                                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.Aria2UseLocal, Mode=TwoWay}" />
                                            <RadioButton
                                                Margin="12,0,0,0"
                                                Content="远程RPC"
                                                GroupName="Aria2Mode"
                                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.Aria2UseLocal, Converter={StaticResource NegationConverter}, Mode=TwoWay}" />

                                            <TextBlock
                                                Margin="12,1,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                Text="选择远程RPC后可填写远程地址" />

                                        </StackPanel>

                                    </StackPanel>


                                </Grid>
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.Aria2UseLocal}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel>
                                        <TextBlock Text="远程Aria2列表" />
                                        <ui:ListView Margin="0,5,0,0" ItemsSource="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.RemoteAria2Nodes}">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListViewItem">
                                                                <Border
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                                    <ContentPresenter />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ui:ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>


                                                        <Ellipse
                                                            Grid.Column="0"
                                                            Width="10"
                                                            Height="10"
                                                            VerticalAlignment="Center"
                                                            Fill="Transparent"
                                                            Stroke="{DynamicResource App.SeparatorBrush}"
                                                            StrokeThickness="1" />

                                                        <Ellipse
                                                            Grid.Column="0"
                                                            Width="10"
                                                            Height="10"
                                                            VerticalAlignment="Center"
                                                            Fill="{DynamicResource App.AccentSecondaryBrush}">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Converter={StaticResource IsSelectedAria2NodeConverter}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>


                                                        <ui:TextBox
                                                            Grid.Column="1"
                                                            Margin="5,0,0,0"
                                                            Text="{Binding URL, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:PasswordBox
                                                            Grid.Column="2"
                                                            Margin="5,0,0,0"
                                                            wpfutils:PasswordBoxAssistant.BindPassword="True"
                                                            wpfutils:PasswordBoxAssistant.BoundPassword="{Binding Token, Mode=TwoWay}" />


                                                        <StackPanel
                                                            Grid.Column="3"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal">
                                                            <Button
                                                                Margin="5,0,0,0"
                                                                Click="ApplyRemoteAria2_Click"
                                                                CommandParameter="{Binding}"
                                                                Content="使用" />
                                                            <Button
                                                                Margin="5,0,0,0"
                                                                Click="RemoveRemoteAria2_Click"
                                                                CommandParameter="{Binding}"
                                                                Content="删除" />
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ui:ListView.ItemTemplate>
                                        </ui:ListView>
                                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                            <Button Click="AddRemoteAria2_Click" Content="新增" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </ui:Card>

                        <ui:Card Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ui:ToggleSwitch
                                    Margin="0,0,16,0"
                                    Content="开机启动"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.LaunchAtStartup}" />

                                
                            </Grid>
                        </ui:Card>
                    </StackPanel>
                </StackPanel>

                <ui:Card Margin="0,10,0,0">
                    <Grid>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:ToggleSwitch
                                    Grid.Column="1"
                                    Content="使用PushDeer推送任务完成"
                                    IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.PushDeerOpen}" />
                            </StackPanel>

                            <ui:TextBox
                                Height="32"
                                MinWidth="400"
                                Margin="0,10,0,0"
                                PlaceholderText="PushDeerKey"
                                Text="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.PushDeerKey}" />
                        </StackPanel>


                    </Grid>
                </ui:Card>

                <ui:Card Margin="0,10,0,0">
                    <Grid>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:ToggleSwitch
                                    Grid.Column="1"
                                    Content="使用代理访问订阅"
                                    IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.SubscriptionProxyOpen}" />
                            </StackPanel>

                            <ui:TextBox
                                Height="32"
                                MinWidth="400"
                                Margin="0,10,0,0"
                                PlaceholderText="http://127.0.0.1:1080"
                                Text="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.SubscriptionProxy}" />
                        </StackPanel>


                    </Grid>

                </ui:Card>
                <TextBlock
                    Margin="0,10,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Text="实验功能" />
                <ui:Card Margin="0,10,0,0">
                    <Grid>
                        <StackPanel>
                            <ui:ToggleSwitch
                                Grid.Column="1"
                                Content="使用AI来提取剧集名称"
                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OpenAIOpen}" />
                            <ui:ToggleSwitch
                                Margin="0,6,0,0"
                                Grid.Column="1"
                                Content="使用AI翻译动漫简介"
                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OpenAISummaryTranslateOpen}" />
                            <ui:ToggleSwitch
                                Margin="0,6,0,0"
                                Grid.Column="1"
                                Content="使用AI生成动漫简评"
                                IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OpenAIAiReviewOpen}" />
                        </StackPanel>
                    </Grid>

                </ui:Card>

                <TextBlock
                    Margin="0,10,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Text="AI配置" />

                <ui:Card Margin="0,10,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource App.TextSecondaryBrush}"
                                Text="可添加多组配置，点击“使用”切换当前生效的配置。" />
                            <ui:Button
                                Grid.Column="1"
                                Appearance="Primary"
                                Click="AddAiConfig_Click"
                                Icon="{ui:SymbolIcon Add24}"
                                Content="添加配置" />
                        </Grid>

                        <ui:ListView
                            Margin="0,10,0,0"
                            ItemsSource="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.AiConfigs}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ui:ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            VerticalAlignment="Center"
                                            Fill="Transparent"
                                            Stroke="{DynamicResource App.SeparatorBrush}"
                                            StrokeThickness="1" />
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            VerticalAlignment="Center"
                                            Fill="{DynamicResource App.AccentSecondaryBrush}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Converter={StaticResource IsSelectedAiConfigConverter}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock
                                                Foreground="{DynamicResource App.TextPrimaryBrush}"
                                                FontWeight="SemiBold"
                                                Text="{Binding Name}" />
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding BaseUrl, Mode=OneWay}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding ModelName, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <ui:Button
                                                Margin="5,0,0,0"
                                                Click="ApplyAiConfig_Click"
                                                CommandParameter="{Binding}"
                                                Content="使用" />
                                            <ui:Button
                                                Margin="5,0,0,0"
                                                Click="EditAiConfig_Click"
                                                CommandParameter="{Binding}"
                                                Content="编辑" />
                                            <ui:Button
                                                Margin="5,0,0,0"
                                                Click="RemoveAiConfig_Click"
                                                CommandParameter="{Binding}"
                                                Content="删除" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ui:ListView.ItemTemplate>
                        </ui:ListView>

                        <TextBlock
                            Margin="2,6,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource App.TextSecondaryBrush}"
                            Text="尚未添加任何 AI 配置，点击右上角“添加配置”开始。"
                            Visibility="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.AiConfigs.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource App.TextPrimaryBrush}" Text="Tavily API Key" />
                        <ui:PasswordBox
                            Height="32"
                            MinWidth="400"
                            Margin="0,5,0,0"
                            wpfutils:PasswordBoxAssistant.BindPassword="True"
                            wpfutils:PasswordBoxAssistant.BoundPassword="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.TavilyKey, Mode=TwoWay}" />
                        <TextBlock Margin="0,4,0,0" FontSize="11" Opacity="0.7" Text="仅在 AI 打分信息不足时，用于 Tavily 搜索和网页抓取补充资料。" />
                    </StackPanel>
                </ui:Card>
                <StackPanel Margin="0,10,0,0" />

                <!--<StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                    <CheckBox Content="订阅列表同步到阿里云OSS（未实现）" IsChecked="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OSSSynchronizeOpen}" ></CheckBox>
                </StackPanel>

                <StackPanel Margin="0,10,0,0" >
                    <Label Content="阿里云OSS-Endpoint"></Label>
                    <StackPanel>
                        <ui:TextBox Text="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OSSEndpoint}" Cursor="IBeam" PlaceholderText="https://oss-cn-hangzhou.aliyuncs.com"  ></ui:TextBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,5,0,0" >
                    <Label Content="阿里云OSS-Bucket"></Label>
                    <StackPanel>
                        <ui:TextBox Text="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OSSBucket}"></ui:TextBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,5,0,0" >
                    <Label Content="阿里云OSS-AccessKey ID" ></Label>
                    <StackPanel>
                        <ui:TextBox Text="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OSSAccessKeyId}"></ui:TextBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,5,0,0" >
                    <Label Content="阿里云OSS-AccessKey Secret"></Label>
                    <StackPanel>
                        <ui:TextBox Text="{Binding Source={x:Static service:AppConfig.Instance}, Path=ConfigData.OSSAccessKeySecret}"></ui:TextBox>
                    </StackPanel>
                </StackPanel>-->


            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
